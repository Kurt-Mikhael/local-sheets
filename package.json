{
  "name": "offline-excel",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "concurrently -n fe,be \"pnpm:dev:fe\" \"pnpm:dev:be\"",
    "dev:fe": "pnpm --filter fe dev",
    "dev:be": "pnpm --filter be dev",
    "build": "pnpm --filter fe build",
    "lint": "eslint ."
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
