# --- Database ---
DATABASE_URL=postgresql://localsheet:localsheet@localhost:5432/localsheet?schema=public
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=30000

# --- App ---
APP_ORIGIN=http://localhost:3000
APP_ORIGIN_EXTRA=
CURSOR_SIGNING_SECRET=replace-with-at-least-32-random-bytes-please-change
SESSION_TTL_DAYS=30
MAX_SYNC_BODY_BYTES=5242880
TRUST_PROXY=loopback
NODE_ENV=development
